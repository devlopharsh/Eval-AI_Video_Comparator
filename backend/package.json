    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.0.12",
    "@nestjs/platform-express": "11.0.12",
    "@prisma/client": "6.8.2",
    "bullmq": "5.53.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dotenv": "16.4.5",
    "ioredis": "5.4.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.7",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.3",
    "@types/node": "22.15.30",
    "@types/supertest": "^7.2.0",
    "prisma": "6.8.2",
    "supertest": "^7.2.2",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
